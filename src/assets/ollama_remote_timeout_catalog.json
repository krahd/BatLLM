  "family_overrides": [
    {
      "pattern": "^all-minilm$",
      "timeout": 20.0,
      "source": "the tiny embedding family rule"
    },
    {
      "pattern": "^smollm2?$",
      "timeout": 35.0,
      "source": "the compact SmolLM family rule"
    },
    {
      "pattern": "^llama3\\.2$",
      "timeout": 75.0,
      "source": "the Llama 3.2 family rule"
    },
    {
      "pattern": "^mistral-small(?:3\\.[12])?$",
      "timeout": 60.0,
      "source": "the Mistral Small family rule"
    },
    {
      "pattern": "^phi3(?:\\.5)?$",
      "timeout": 90.0,
      "source": "the Phi 3 family rule"
    },
    {
      "pattern": "^phi4(?:-mini|-reasoning|-mini-reasoning)?$",
      "timeout": 105.0,
      "source": "the Phi 4 family rule"
    },
    {
      "pattern": "^qwen3$",
      "timeout": 120.0,
      "source": "the Qwen 3 family rule"
    },
    {
      "pattern": "^qwen3-coder$",
      "timeout": 150.0,
      "source": "the Qwen 3 coder family rule"
    },
    {
      "pattern": "^qwen3-vl$",
      "timeout": 150.0,
      "source": "the Qwen 3 multimodal family rule"
    },
    {
      "pattern": "^qwen3-embedding$",
      "timeout": 45.0,
      "source": "the Qwen 3 embedding family rule"
    },
    {
      "pattern": "^deepseek-r1$",
      "timeout": 180.0,
      "source": "the DeepSeek R1 family rule"
    },
    {
      "pattern": "^deepseek-coder(?:-v2)?$",
      "timeout": 150.0,
      "source": "the DeepSeek coder family rule"
    },
    {
      "pattern": "^gemma3n?$",
      "timeout": 90.0,
      "source": "the Gemma 3 family rule"
    },
    {
      "pattern": "^gemma4$",
      "timeout": 150.0,
      "source": "the Gemma 4 family rule"
    },
    {
      "pattern": "^mixtral$",
      "timeout": 180.0,
      "source": "the Mixtral family rule"
    },
    {
      "pattern": "^gpt-oss(?:-safeguard)?$",
      "timeout": 180.0,
      "source": "the GPT-OSS family rule"
    },
    {
      "pattern": "^command-r7b(?:-arabic)?$",
      "timeout": 80.0,
      "source": "the Command R7B family rule"
    },
    {
      "pattern": "^command-r$",
      "timeout": 150.0,
      "source": "the Command R family rule"
    },
    {
      "pattern": "^command-r-plus$",
      "timeout": 210.0,
      "source": "the Command R+ family rule"
    },
    {
      "pattern": "^command-a$",
      "timeout": 240.0,
      "source": "the Command A family rule"
    },
    {
      "pattern": "^devstral(?:-small-2|-2)?$",
      "timeout": 150.0,
      "source": "the Devstral family rule"
    },
    {
      "pattern": "^nomic-embed-text(?:-v2-moe)?$",
      "timeout": 30.0,
      "source": "the Nomic embedding family rule"
    },
    {
      "pattern": "^snowflake-arctic-embed2?$",
      "timeout": 30.0,
      "source": "the Snowflake embedding family rule"
    },
    {
      "pattern": "^mxbai-embed-large$",
      "timeout": 45.0,
      "source": "the MXBAI embedding family rule"
    },
    {
      "pattern": "^bge-(?:m3|large)$",
      "timeout": 30.0,
      "source": "the BGE embedding family rule"
    }
  ],
  "keyword_adjustments": [
    {
      "pattern": "embed|embedding",
      "offset": -40.0,
      "minimum": 20.0,
      "source": "an embedding-model adjustment"
    },
    {
      "pattern": "vision|vl|llava|ocr|moondream|bakllava|minicpm-v",
      "offset": 25.0,
      "minimum": 70.0,
      "source": "a multimodal-model adjustment"
    },
    {
      "pattern": "coder|code|sql|devstral|starcoder|codestral",
      "offset": 15.0,
      "minimum": 60.0,
      "source": "a coding-model adjustment"
    },
    {
      "pattern": "reason|thinking|r1|qwq|math",
      "offset": 25.0,
      "minimum": 75.0,
      "source": "a reasoning-model adjustment"
    },
    {
      "pattern": "guard|safeguard",
      "offset": 10.0,
      "minimum": 45.0,
      "source": "a safety-model adjustment"
    },
    {
      "pattern": "mixtral|dbrx|nemotron|command-a|command-r-plus|deepseek-v3|glm-5|minimax|kimi|qwen3-next",
      "offset": 45.0,
      "minimum": 180.0,
      "source": "a very-large-model adjustment"
    }
  ]
}