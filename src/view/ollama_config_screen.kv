#:kivy 2.3.1

<OllamaConfigScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(30)
        spacing: dp(16)

        Label:
            text: "Ollama Configuration"
            color: 0, 0, 0, 1
            font_size: sp(34)
            size_hint_y: None
            height: self.texture_size[1] + dp(6)

        Label:
            text: root.status_text
            color: 0.1, 0.2, 0.35, 1
            font_size: sp(18)
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(10)

            Button:
                text: "Start Ollama"
                font_size: sp(20)
                background_color: .6, .8, .9, .8
                color: 1, 1, 1, 1
                on_press: root.start_ollama()

            Button:
                text: "Stop Ollama"
                font_size: sp(20)
                background_color: 1, .7, .8, .9
                color: 1, 1, 1, 1
                on_press: root.stop_ollama()

            Button:
                text: "Refresh"
                font_size: sp(20)
                background_color: .8, .8, .8, 1
                color: 1, 1, 1, 1
                on_press: root.refresh_all()

        BoxLayout:
            size_hint_y: 1
            orientation: "vertical"
            spacing: dp(8)
            padding: 0, dp(12), 0, 0

            Label:
                text: "Ollama Status"
                color: 0, 0, 0, 1
                font_size: sp(22)
                size_hint_y: None
                height: self.texture_size[1] + dp(4)
                halign: "left"
                text_size: self.width, None

            Label:
                text: root.status_details
                color: 0.15, 0.15, 0.15, 1
                font_size: sp(16)
                size_hint_y: None
                height: max(self.texture_size[1] + dp(10), dp(96))
                halign: "left"
                valign: "top"
                text_size: self.width, None

            Widget:
                size_hint_y: None
                height: dp(12)

            Label:
                text: "Output"
                color: 0, 0, 0, 1
                font_size: sp(22)
                size_hint_y: None
                height: self.texture_size[1] + dp(4)
                halign: "left"
                text_size: self.width, None

            ScrollView:
                id: output_scroll
                size_hint_y: 1
                do_scroll_x: False
                scroll_type: ["bars", "content"]
                bar_width: dp(10)

                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Label:
                    id: output_log_box
                    text: root.output_log if root.output_log else " "
                    size_hint_y: None
                    height: max(self.texture_size[1] + dp(16), output_scroll.height)
                    color: 1, 1, 1, 1
                    font_size: sp(14)
                    halign: "left"
                    valign: "top"
                    text_size: self.width - dp(16), None

        BoxLayout:
            spacing: dp(20)
            size_hint_y: None
            height: dp(130)

            BoxLayout:
                orientation: "vertical"
                spacing: dp(10)

                Label:
                    text: "Local Models"
                    color: 0, 0, 0, 1
                    font_size: sp(22)
                    size_hint_y: None
                    height: self.texture_size[1] + dp(4)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(8)

                    Button:
                        id: local_spinner
                        text: root.selected_local_model_label
                        size_hint_x: 0.55
                        shorten: True
                        halign: "left"
                        valign: "middle"
                        text_size: self.width - dp(16), None
                        color: 0, 0, 0, 1
                        background_color: .95, .95, .95, 1
                        on_press: root.open_local_model_selector()

                    Button:
                        text: "Use Selected"
                        font_size: sp(18)
                        size_hint_x: 0.22
                        on_press: root.set_model_from_selection()

                    Button:
                        text: "Delete Selected"
                        font_size: sp(18)
                        size_hint_x: 0.23
                        background_color: 1, .7, .8, .9
                        color: 1, 1, 1, 1
                        on_press: root.request_delete_selected_model()

            BoxLayout:
                orientation: "vertical"
                spacing: dp(10)

                Label:
                    text: "Remote Models"
                    color: 0, 0, 0, 1
                    font_size: sp(22)
                    size_hint_y: None
                    height: self.texture_size[1] + dp(4)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    spacing: dp(8)

                    Button:
                        id: remote_spinner
                        text: root.selected_remote_model_label
                        size_hint_x: 0.72
                        shorten: True
                        halign: "left"
                        valign: "middle"
                        text_size: self.width - dp(16), None
                        color: 0, 0, 0, 1
                        background_color: .95, .95, .95, 1
                        on_press: root.open_remote_model_selector()

                    Button:
                        text: "Download Selected"
                        font_size: sp(18)
                        size_hint_x: 0.28
                        background_color: .6, .8, .9, .8
                        color: 1, 1, 1, 1
                        on_press: root.request_pull_selected_model()

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: 0, dp(6), 0, 0

            Button:
                text: "Back to Settings"
                font_size: sp(20)
                background_color: .6, .8, .9, .8
                color: 1, 1, 1, 1
                on_press: root.go_to_settings_screen()
